{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r \".tool_input.file_path // empty\"); case \"$FILE\" in *.mmd) export PATH=\"$HOME/bin:$PATH\"; maid \"$FILE\" 2>/dev/null; if [ $? -eq 0 ]; then mermaid-render \"$FILE\" \"${FILE%.mmd}.svg\" 2>/dev/null; mermaid-render \"$FILE\" \"${FILE%.mmd}.png\" -s 3 2>/dev/null; fi ;; esac'",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
