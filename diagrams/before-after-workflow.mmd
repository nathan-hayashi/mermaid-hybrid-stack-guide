flowchart LR
    subgraph BEFORE["BEFORE -- Manual Workflow (slow, error-prone)"]
        direction LR
        B1["Write Code"] -->|"developer done"| B2["Manual Review"]
        B2 -->|"reviewer flags issues"| B3["Fix Issues"]
        B3 -->|"re-submit"| B4["Re-review"]
        B4 -->|"approved"| B5["Merge"]
    end

    subgraph AFTER["AFTER -- Orchestrated Workflow (automated, fast)"]
        direction LR
        A1["Write Code"] -->|"save file"| A2["Auto-Format Hook<br/>(PostToolUse -- Prettier)"]
        A2 -->|"complexity scored"| A3["Threshold Router<br/>(T1 / T2 / T3)"]
        A3 -->|"T2 or T3"| A4["Parallel Review"]

        subgraph A4["Parallel Review (spawned subagents)"]
            direction TB
            R1["Security<br/>Reviewer"]
            R2["Quality<br/>Reviewer"]
            R3["Fixer<br/>Agent"]
        end

        A4 -->|"all reviewers pass"| A5["Auto-Merge"]
    end

    BEFORE ~~~ AFTER

